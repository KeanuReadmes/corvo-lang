sys.echo("")
sys.echo("=== notifications.x ===")
try {
    var.set("x_result", notifications.x(
        "your-api-key",
        "your-api-secret",
        "your-access-token",
        "your-access-token-secret",
        "Hello from Corvo! #corvolang"
    ))
    sys.echo("X status: ${map.get(var.get("x_result"), "status_code")}")
