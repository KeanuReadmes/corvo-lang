# notifications_example.corvo — notifications.*
# NOTE: All examples require valid credentials and network access.
#       Each call is wrapped in try/fallback so the file runs cleanly offline
#       or without real credentials.

sys.echo("=== notifications.smtp ===")
try {
    var.set("smtp_result", notifications.smtp(
        "smtp.example.com",
        587,
        "user@example.com",
        "secret",
        "user@example.com",
        "recipient@example.com",
        "Hello from Corvo",
        "This message was sent by the Corvo notifications library."
    ))
    sys.echo("SMTP sent: ${map.get(var.get("smtp_result"), "success")}")
} fallback {
    sys.echo("(skipped — no SMTP server configured)")
}

sys.echo("")
sys.echo("=== notifications.slack ===")
try {
    var.set("slack_result", notifications.slack(
        "https://hooks.slack.com/services/YOUR/WEBHOOK/URL",
        "Hello from Corvo!"
    ))
    sys.echo("Slack status: ${map.get(var.get("slack_result"), "status_code")}")
} fallback {
    sys.echo("(skipped — no Slack webhook configured)")
}

sys.echo("")
sys.echo("=== notifications.telegram ===")
try {
    var.set("tg_result", notifications.telegram(
        "123456:ABC-YOUR-BOT-TOKEN",
        "-1001234567890",
        "Hello from Corvo!"
    ))
    sys.echo("Telegram status: ${map.get(var.get("tg_result"), "status_code")}")
} fallback {
    sys.echo("(skipped — no Telegram bot configured)")
}

